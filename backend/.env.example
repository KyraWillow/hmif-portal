# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hmif_portal?sslmode=disable
ADMIN_TOKEN=change-this-admin-token

# Optional runtime settings
PORT=8080
GIN_MODE=release
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app,https://*.vercel.app

# Alternative database config (use this only if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hmif_portal
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta
